generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum StockMovementType {
  PURCHASE_ADDED
  INVOICE_SOLD
  ECOMMERCE_SOLD
  MANUAL_ADJUSTMENT
  RETURN
  DAMAGED
  CANCELLED_RESTORED
}

enum ProductUnit {
  PIECE
  BOX
  KG
  LITER
  METER
  SET
  PACK
  ROLL
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String?
  role          Role     @default(CUSTOMER)
  image         String?
  emailVerified DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  customers      Customer[]
  invoices       Invoice[]
  orders         Order[]
  stockMovements InventoryTransaction[]
  auditLogs      AuditLog[]
  cart           Cart?
  invoicePayments InvoicePayment[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// COMPANY SETTINGS
// ============================================================

model CompanySetting {
  id                    String   @id @default(cuid())
  companyName           String   @default("Multi Solutions Company")
  companyLogo           String?
  letterheadImage       String?
  footerImage           String?
  address               String?
  phone                 String?
  email                 String?
  website               String?
  taxNumber             String?  // NTN
  invoicePrefix         String   @default("MSC-INV")
  currency              String   @default("PKR")
  currencySymbol        String   @default("Rs")
  defaultTaxPercentage  Float    @default(0)
  defaultInvoiceNotes   String?
  defaultInvoiceTerms   String?
  storeName             String   @default("Multi Solutions Store")
  storeDescription      String?
  storeLive             Boolean  @default(false)
  invoiceAffectsStock   Boolean  @default(true)
  orderReservesStock    Boolean  @default(true)
  shippingFee           Float    @default(0)
  freeShippingThreshold Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================================
// CATEGORY
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([slug])
  @@index([parentId])
}

// ============================================================
// PRODUCT
// ============================================================

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  sku              String        @unique
  description      String?
  shortDescription String?
  barcode          String?
  costPrice        Float
  sellingPrice     Float
  comparePrice     Float?
  quantityInStock  Int           @default(0)
  lowStockThreshold Int          @default(10)
  unit             ProductUnit   @default(PIECE)
  status           ProductStatus @default(DRAFT)
  trackInventory   Boolean       @default(true)
  featured         Boolean       @default(false)
  taxPercentage    Float         @default(0)
  brand            String?
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  categoryId       String?
  category         Category?     @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  variants         ProductVariant[]
  invoiceItems     InvoiceItem[]
  orderItems       OrderItem[]
  stockTransactions InventoryTransaction[]
  cartItems        CartItem[]

  @@index([slug])
  @@index([sku])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id             String   @id @default(cuid())
  name           String
  sku            String   @unique
  option1Name    String?
  option1Value   String?
  option2Name    String?
  option2Value   String?
  option3Name    String?
  option3Value   String?
  costPrice      Float?
  sellingPrice   Float?
  comparePrice   Float?
  quantityInStock Int      @default(0)
  image          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  invoiceItems    InvoiceItem[]
  orderItems      OrderItem[]
  stockTransactions InventoryTransaction[]
  cartItems        CartItem[]

  @@index([productId])
  @@index([sku])
}

// ============================================================
// INVENTORY TRANSACTIONS
// ============================================================

model InventoryTransaction {
  id              String            @id @default(cuid())
  movementType    StockMovementType
  quantity        Int
  beforeQuantity  Int
  afterQuantity   Int
  referenceType   String?           // "invoice", "order", "purchase", "manual"
  referenceId     String?
  notes           String?
  createdAt       DateTime          @default(now())

  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([variantId])
  @@index([movementType])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

// ============================================================
// CUSTOMER
// ============================================================

model Customer {
  id              String   @id @default(cuid())
  name            String
  companyName     String?
  email           String?
  phone           String?
  billingAddress  String?
  shippingAddress String?
  taxId           String?  // NTN
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Link to user account if customer has one
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  invoices Invoice[]
  orders   Order[]

  @@index([email])
  @@index([phone])
}

// ============================================================
// INVOICE
// ============================================================

model Invoice {
  id               String        @id @default(cuid())
  invoiceNumber    String        @unique
  status           InvoiceStatus @default(DRAFT)
  paymentStatus    PaymentStatus @default(UNPAID)
  issueDate        DateTime      @default(now())
  dueDate         DateTime?
  subtotal         Float         @default(0)
  discountAmount   Float         @default(0)
  taxAmount        Float         @default(0)
  totalAmount      Float         @default(0)
  amountPaid       Float         @default(0)
  notes            String?
  terms            String?
  affectsStock     Boolean       @default(true)
  stockDeducted    Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Bill-to fields (can be different from customer record)
  billToName        String?
  billToCompany     String?
  billToEmail       String?
  billToPhone       String?
  billToAddress     String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  items    InvoiceItem[]
  payments InvoicePayment[]

  @@index([invoiceNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([createdAt])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  name        String
  description String?
  quantity    Float   @default(1)
  unitPrice   Float
  taxRate     Float   @default(0)
  discount    Float   @default(0)
  lineTotal   Float   @default(0)
  sortOrder   Int     @default(0)

  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product?  @relation(fields: [productId], references: [id])

  variantId      String?
  productVariant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

model InvoicePayment {
  id            String        @id @default(cuid())
  amount        Float
  paymentDate   DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  @@index([invoiceId])
}

// ============================================================
// ORDER (E-COMMERCE)
// ============================================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  customerName    String
  customerEmail   String?
  customerPhone   String?
  shippingAddress String?
  shippingCity    String?
  shippingNotes   String?
  subtotal        Float       @default(0)
  shippingFee     Float       @default(0)
  discountAmount  Float       @default(0)
  taxAmount       Float       @default(0)
  totalAmount     Float       @default(0)
  paymentMethod   String      @default("COD")
  paymentStatus   PaymentStatus @default(UNPAID)
  notes           String?
  confirmedAt     DateTime?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Link to customer if logged in
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  items OrderItem[]

  @@index([orderNumber])
  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  productName String
  productSku  String?
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  orderId String
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  variantId      String?
  productVariant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ============================================================
// CART (for logged-in store customers)
// ============================================================

model Cart {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]

  @@index([userId])
}

model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId      String?
  productVariant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

// ============================================================
// UPLOADED ASSET
// ============================================================

model UploadedAsset {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimetype  String
  size      Int
  category  String?  // "logo", "letterhead", "footer", "product"
  createdAt DateTime @default(now())

  @@index([category])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // "create", "update", "delete", "login"
  entity    String   // "product", "invoice", "order", etc.
  entityId  String?
  details   String?  // JSON string of changes
  ipAddress String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}
